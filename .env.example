# =============================================================================
# Whale Alert EL Pipeline — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# MinIO Configuration
# ---------------------------------------------------------------------------
# Full URL to the MinIO API endpoint (port 9000 by default)
MINIO_ENDPOINT=http://minio:9000

# Credentials — change these before running in any environment
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Bucket where CSV files will be stored
MINIO_BUCKET_NAME=whale-alert

# ---------------------------------------------------------------------------
# Whale Alert Scraper
# ---------------------------------------------------------------------------
WHALE_URL=https://whale-alert.io/whales.html

# ---------------------------------------------------------------------------
# Airflow Core
# ---------------------------------------------------------------------------
# Secret key for Flask sessions & Fernet encryption — generate a new one:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=YOUR_FERNET_KEY_HERE

# Use LocalExecutor for single-node setups (no Celery/Redis required)
AIRFLOW__CORE__EXECUTOR=LocalExecutor

# Disable example DAGs to keep the UI clean
AIRFLOW__CORE__LOAD_EXAMPLES=False

# Metadata DB connection — points to the postgres service defined in compose
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres:5432/airflow

# ---------------------------------------------------------------------------
# Postgres (Airflow Metadata DB)
# ---------------------------------------------------------------------------
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow
